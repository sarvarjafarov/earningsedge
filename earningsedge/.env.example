# =============================================================================
# EarningsEdge — copy to `.env` and fill in values. Do not commit `.env`.
# See repository README for env documentation: ../README.md
# =============================================================================

# --- Core (needed for most dashboard + agent features) ---
GEMINI_API_KEY=your_key_here
ALPHA_VANTAGE_API_KEY=your_key_here
FINNHUB_API_KEY=your_key_here
FMP_API_KEY=your_key_here

# --- Macro panel (U.S. Treasury curve + economic series via FRED) ---
FRED_API_KEY=your_fred_key_here

# --- Alpaca paper trading (optional; BUY/SELL confirmation in UI) ---
# ALPACA_API_KEY=your_paper_key_here
# ALPACA_SECRET_KEY=your_paper_secret_here
# ALPACA_BASE_URL=https://paper-api.alpaca.markets

# --- CORS (production: set to your deployed UI origin(s), comma-separated) ---
# ALLOWED_ORIGINS=https://your-service.run.app

# --- Telegram: short “summary ready on EarningsEdge” ping to a team group (optional) ---
# Create a bot with @BotFather, add it to the group, then set chat id (often negative for groups).
# TELEGRAM_BOT_TOKEN=123456:ABC...
# TELEGRAM_NOTIFY_CHAT_ID=-1001234567890
# Optional second line in the ping with your deployed or local UI URL:
# EARNINGS_EDGE_PUBLIC_URL=https://your-app.example.com

# --- Gemini model overrides (defaults below are fine for the hackathon) ---
# GEMINI_MODEL=gemini-3.5-flash
# GEMINI_LIVE_MODEL=gemini-3.1-flash-live-preview
# GEMINI_TTS_MODEL=gemini-2.5-flash-preview-tts

# --- MongoDB Atlas + MCP partner-track integration (hackathon-required) ---
# Atlas SRV connection string from cloud.mongodb.com → Cluster → Connect → Drivers.
# MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/?retryWrites=true
# MONGODB_DB=earningsedge
# URL of the official mongodb-mcp-server (Streamable HTTP). Run locally with:
#   npx -y mongodb-mcp-server@latest --transport http --httpPort 8088
# or point this at a hosted instance. Falls back to direct pymongo on failure.
# MONGODB_MCP_URL=http://127.0.0.1:8088
# MCP_TIMEOUT_S=10

# --- Repo tooling only (Cursor MCP sync script); not read by the FastAPI app ---
# Used only if you run: python scripts/sync_cursor_mcp.py
